# Voice Mode: "mock" | "live"
VOICE_MODE=mock

# Internal communication between web and voice-worker
VOICE_WORKER_INTERNAL_SECRET=

# URLs
APP_BASE_URL=http://localhost:3000
VOICE_WORKER_BASE_URL=http://localhost:3001
