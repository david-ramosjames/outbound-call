{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm --filter @outbound-call/shared build && pnpm --filter @outbound-call/web build"
  },
  "deploy": {
    "startCommand": "pnpm --filter @outbound-call/web start",
    "healthcheckPath": "/api/health",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
